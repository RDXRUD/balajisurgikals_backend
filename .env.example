# MongoDB Atlas
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=balaji_surgikals

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=10080

# Admin credentials (seeded on first startup)
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Oracle Cloud Object Storage (Always Free)
# Namespace: OCI Console → Object Storage → Bucket details
# Region: e.g. ap-mumbai-1, us-ashburn-1
# Access/Secret: OCI Console → Profile → Customer Secret Keys → Generate
OCI_NAMESPACE=<oci-namespace>
OCI_REGION=<oci-region>
OCI_BUCKET=<oci-bucket-name>
OCI_ACCESS_KEY=<oci-access-key>
OCI_SECRET_KEY=<oci-secret-key>
